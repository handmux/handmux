    "dev": "node bin/handmux.js start --foreground",
    "handmux": "node bin/handmux.js",
    "bundle": "node scripts/bundle-web.mjs",
    "prepack": "node scripts/bundle-web.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "busboy": "^1.6.0",
    "express": "^4.19.2",
    "tunlite": "^0.10.0",
    "web-push": "^3.6.7"
  },
  "optionalDependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^2.0.0"
  },
